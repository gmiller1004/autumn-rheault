# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# demo reel source files (host via Vercel Blob, not git)
*.mp4
*.mov
/public/*.mp4

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# original full-size camera uploads at public root (optimized copies live elsewhere)
/public/IMG_*
/public/JY0A*
/public/*.CR2
